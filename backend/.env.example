# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
# 开发阶段可设置为 true 使用 SQLite（无需安装 MySQL）
USE_SQLITE=true

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=xinshige

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# 阿里云短信配置
SMS_ACCESS_KEY_ID=your_aliyun_access_key
SMS_ACCESS_KEY_SECRET=your_aliyun_secret
SMS_SIGN_NAME=your_sign_name
SMS_TEMPLATE_CODE=your_template_code
SMS_MOCK=true

# 微信支付配置
WECHAT_APPID=your_wechat_appid
WECHAT_MCHID=your_mchid
WECHAT_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=https://yourdomain.com/api/pay/notify/wechat

# 支付宝配置
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/pay/notify/alipay

# Apple IAP配置
APPLE_SHARED_SECRET=your_apple_shared_secret

# 支付Mock开关（开发阶段使用）
PAY_MOCK=true

# 阿里云OSS配置
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_oss_key
OSS_ACCESS_KEY_SECRET=your_oss_secret
OSS_BUCKET=your_bucket_name
